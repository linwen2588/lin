# 忽略操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 忽略编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 忽略 Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 忽略虚拟环境
venv/
env/
ENV/

# 忽略日志文件
*.log

# 忽略临时文件
*.tmp
*.temp
.cache/

# 忽略大文件（可选，如果你不想把原图推送到 GitHub）
# images/**/*.jpg
# images/**/*.jpeg
# images/**/*.png
# images/**/*.webp

# 但保留 data 目录下的 JSON 文件
!data/*.json
